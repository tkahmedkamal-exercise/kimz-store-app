echo "Running lint..."
npm run lint || {
  echo
  echo "❌ Lint failed — fix the problems listed above (file:line:column) before committing."
  echo "   Tip: run 'npm run lint -- --fix' to auto-fix what's fixable."
  exit 1
}

echo "Running type-check..."
npm run type-check || {
  echo
  echo "❌ Type-check failed — fix the type errors listed above before committing."
  exit 1
}

echo "All checks passed. Proceeding with commit."
